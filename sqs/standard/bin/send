#!/usr/bin/env bash
 
root_path=$(realpath .)
message_attributes_path="file://${root_path}/send-message.json"

echo "== send"

QUEUE_URL=https://sqs.us-east-1.amazonaws.com/378950443697/sqs-standard-MyQueue-jE8nngfLcqRC

aws sqs send-message \
--queue-url $QUEUE_URL \
--message-body "Hello Mars!" \
--delay-seconds 0 \
--message-attributes "$message_attributes_path"

